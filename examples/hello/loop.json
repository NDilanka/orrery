{
  "id": "hello",
  "name": "hello — fix mathlib until green (pytest)",
  "theme": "ember",
  "kind": "generic",
  "stateDir": ".loop",
  "adapter": "generic",
  "engine": {
    "task": "TASK.md",
    "models": { "discover": "haiku", "execute": "sonnet", "judge": "haiku", "hard": "opus" },
    "maxTurns": 20,
    "allowedTools": ["Read", "Edit", "Write", "Bash(pytest)", "Bash(pytest:*)"],
    "permissionMode": "acceptEdits",
    "gate": {
      "stages": [
        {
          "name": "test",
          "command": "pytest -q",
          "passPattern": "(\\d+) passed",
          "failPattern": "(\\d+) failed",
          "lockGlobs": ["**/test_*.py"]
        }
      ],
      "greenWhen": "exit==0",
      "lockGlobs": ["**/test_*.py"]
    },
    "cost": { "ceilingUsd": 0.5, "alertPct": [50, 80, 100] },
    "stop": { "maxIters": 8, "stagnationLimit": 2, "plateauLimit": 3, "regressLimit": 3, "gracefulAtPhase": true },
    "verify": { "judgeModel": "haiku", "contract": [] }
  }
}
